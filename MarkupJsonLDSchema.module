    public function ___render($name = null, ?array $options = null, ?Page $page = null): string
    {
        $options = is_array($options) ? $options : [];
        $data = array_merge(self::$defaults, wire('modules')->getConfig($this), $options);

        if($name === 'Person') {
            $this->limitPersonInheritedFields($data, $options);
        }

        if(is_null($page)) {
            $page = wire('page');
        }

        if(is_null($name)) {
            return 'No schema name given';
        }

        $sanitizer = wire('sanitizer');

        if($name === 'BreadcrumbList' && (int) $page->id === 1) {
            return '';
        }

        $className = 'JsonLD' . $sanitizer->name($name);
        $schemaClass = $this->loadSchemaClass($className);

        if(!$schemaClass) {
            throw new WireException("Class {$className} could not be loaded");
        }

        if(!method_exists($schemaClass, 'getSchema')) {
            $this->error("Schema class {$className} does not implement getSchema()", Notice::log);
            throw new WireException("Class {$className} is invalid");
        }

        $result = $schemaClass->getSchema($data, $page);

        if(!is_array($result)) {
            throw new WireException("Class {$className} did not return a schema array");
        }

        if(!empty($data['custom']) && is_array($data['custom'])) {
            foreach($data['custom'] as $key => $value) {
                $cleanKey = trim((string) $key);
                if($cleanKey === '') continue;

                $cleanVal = $this->sanitizeCustomValue($value);
                if($cleanVal !== null && $cleanVal !== '' && $cleanVal !== []) {
                    $result[$cleanKey] = $cleanVal;
                }
            }
        }

        $result = $this->normalizeSchemaResult($result);

        return json_encode($result, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
    }

    protected function sanitizeCustomValue(mixed $value): mixed
    {
        $sanitizer = $this->wire('sanitizer');

        if(is_array($value)) {
            $out = [];

            foreach($value as $key => $item) {
                if(is_int($key)) {
                    $cleanItem = $this->sanitizeCustomValue($item);
                    if($cleanItem !== null && $cleanItem !== '' && $cleanItem !== []) {
                        $out[] = $cleanItem;
                    }
                } else {
                    $cleanKey = trim((string) $key);
                    if($cleanKey === '') continue;

                    $cleanItem = $this->sanitizeCustomValue($item);
                    if($cleanItem !== null && $cleanItem !== '' && $cleanItem !== []) {
                        $out[$cleanKey] = $cleanItem;
                    }
                }
            }

            return $out;
        }

        if(is_scalar($value)) {
            $clean = $sanitizer->text((string) $value);
            return $clean !== '' ? $clean : null;
        }

        return null;
    }

    protected function limitPersonInheritedFields(array &$data, array $options): void
    {
        $explicitOnly = [
            'email',
            'telephone',
            'same_as',
            'street_address',
            'address_locality',
            'address_region',
            'postcode',
            'address_country',
            'image',
            'logo',
        ];

        foreach($explicitOnly as $key) {
            if(!array_key_exists($key, $options)) {
                unset($data[$key]);
            }
        }
    }

    protected function normalizeSchemaResult(array $result): array
    {
        return $this->normalizeAddressResult($result);
    }

    protected function normalizeAddressResult(array $result): array
    {
        $address = array_filter([
            'streetAddress' => $result['streetAddress'] ?? '',
            'addressLocality' => $result['addressLocality'] ?? '',
            'addressRegion' => $result['addressRegion'] ?? '',
            'postalCode' => $result['postalCode'] ?? '',
            'addressCountry' => $result['addressCountry'] ?? '',
        ]);

        unset(
            $result['streetAddress'],
            $result['addressLocality'],
            $result['addressRegion'],
            $result['postalCode'],
            $result['addressCountry']
        );

        if(!empty($address)) {
            $result['address'] = array_merge(['@type' => 'PostalAddress'], $address);
        }

        return $result;
    }

    private function loadSchemaClass(string $class): mixed
    {
        $short = ltrim($class, '\\');
        $fqcn = __NAMESPACE__ . '\\' . $short;

        // JsonLDWebSite -> WebSite => schemas/jsonld.WebSite.php
        $fileKey = preg_replace('/^JsonLD/', '', $short);
        if(!$fileKey) {
            $this->error("Invalid schema class name: {$class}", Notice::log);
            return false;
        }

        $schemaPath = __DIR__ . '/schemas/jsonld.' . $fileKey . '.php';

        if(!is_file($schemaPath)) {
            $this->error("Schema file not found for {$class}: {$schemaPath}", Notice::log);
            return false;
        }

        require_once $schemaPath;

        if(!class_exists($fqcn, false)) {
            $this->error("Schema class {$fqcn} not found in {$schemaPath}", Notice::log);
            return false;
        }

        return new $fqcn();
    }
    #---------------------
    # Hooks
    #---------------------  
    
    // There are no module hooks but render and ready methods are hookable
    
    #---------------------
    # Helpers
    #---------------------  

}
