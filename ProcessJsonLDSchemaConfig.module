<?php namespace ProcessWire;

class ProcessJsonLDSchemaConfig extends Process {

    public function ___execute() {
        $modules = $this->wire('modules');
        $input = $this->wire('input');
        $targetModule = 'MarkupJsonLDSchema';

        $savedConfig = $modules->getConfig($targetModule);
        if(!is_array($savedConfig)) $savedConfig = [];

        $form = $this->buildForm($savedConfig);

        if($input->post('submit_save')) {
            $form->processInput($input->post);
            $newConfig = [];
            foreach($this->getFieldDefinitions() as $fieldsetKey => $fieldset) {
                foreach($fieldset['children'] as $name => $def) {
                    $newConfig[$name] = $form->getChildByName($name)->val();
                }
            }
            // Save template mappings
            $newConfig['template_mappings'] = $this->processTemplateMappings($input->post);
            $modules->saveConfig($targetModule, $newConfig);
            $this->message($this->_('Configuración guardada'));

            // Validate mappings
            $this->validateMappings($newConfig['template_mappings']);

            $this->wire('session')->redirect($this->wire('page')->url);
        }

        return $form->render();
    }

    protected function buildForm(array $savedConfig): InputfieldForm {
        $modules = $this->wire('modules');
        $form = $modules->get('InputfieldForm');
        $form->attr('method', 'post');
        $form->attr('action', './');

        foreach($this->getFieldDefinitions() as $fieldsetKey => $fieldset) {
            $fs = $modules->get('InputfieldFieldset');
            $fs->label = $fieldset['label'];
            if(isset($fieldset['columnWidth'])) $fs->columnWidth = $fieldset['columnWidth'];

            foreach($fieldset['children'] as $name => $def) {
                $type = $def['type'] === 'url' ? 'InputfieldURL' : 
                       ($def['type'] === 'textarea' ? 'InputfieldTextarea' : 'InputfieldText');
                $f = $modules->get($type);
                $f->attr('name', $name);
                $f->label = $def['label'];
                if(isset($def['description'])) $f->description = $def['description'];
                if(isset($def['columnWidth'])) $f->columnWidth = $def['columnWidth'];
                if(isset($def['stripTags'])) $f->stripTags = $def['stripTags'];
                $f->attr('value', $savedConfig[$name] ?? $def['value']);
                $fs->add($f);
            }

            $form->add($fs);
        }

        // Template Mappings section
        $form->add($this->buildTemplateMappingsFieldset($savedConfig));

        $submit = $modules->get('InputfieldSubmit');
        $submit->attr('name', 'submit_save');
        $submit->attr('value', $this->_('Guardar'));
        $form->add($submit);

        return $form;
    }

    /**
     * Build the Template Mappings fieldset
     */
    protected function buildTemplateMappingsFieldset(array $savedConfig): InputfieldFieldset {
        $modules = $this->wire('modules');
        $templates = $this->wire('templates');

        $jsonld = $modules->get('MarkupJsonLDSchema');
        $schemas = $jsonld->getMappableKeys();
        $mappings = $savedConfig['template_mappings'] ?? [];

        $excludeTemplates = ['admin', 'form-builder', 'settings'];

        $fs = $modules->get('InputfieldFieldset');
        $fs->label = $this->_('Template Mappings');
        $fs->description = $this->_('Associate JSON-LD schemas to templates and map their keys to template fields.');
        $fs->icon = 'sitemap';
        $fs->collapsed = Inputfield::collapsedYes;

        foreach($templates as $template) {
            if(in_array($template->name, $excludeTemplates)) continue;
            if(!$template->fields->count()) continue;

            $templateMapping = $mappings[$template->name] ?? [];

            $tfs = $modules->get('InputfieldFieldset');
            $tfs->label = $template->name;
            $tfs->collapsed = empty($templateMapping) ? Inputfield::collapsedYes : Inputfield::collapsedNo;
            $tfs->icon = 'file-text-o';

            // Schema selector
            $f = $modules->get('InputfieldAsmSelect');
            $f->attr('name', "tm_{$template->name}_schemas");
            $f->label = $this->_('Schemas');
            $f->description = $this->_('Select which schemas to generate for this template.');
            foreach(array_keys($schemas) as $schemaName) {
                $f->addOption($schemaName, $schemaName);
            }
            $f->attr('value', array_keys($templateMapping));
            $tfs->add($f);

            // Field mappings per selected schema
            $templateFields = ['_auto_' => $this->_('— Auto (schema default) —')];
            foreach($template->fields as $field) {
                $templateFields[$field->name] = $field->name . ' (' . $field->type->shortName . ')';
            }

            foreach($templateMapping as $schemaName => $keyMap) {
                if(!isset($schemas[$schemaName])) continue;
                $sfs = $modules->get('InputfieldFieldset');
                $sfs->label = sprintf($this->_('Mapping: %s'), $schemaName);
                $sfs->collapsed = Inputfield::collapsedNo;

                foreach($schemas[$schemaName] as $key) {
                    $sf = $modules->get('InputfieldSelect');
                    $sf->attr('name', "tm_{$template->name}_{$schemaName}_{$key}");
                    $sf->label = $key;
                    $sf->addOptions($templateFields);
                    $sf->attr('value', $keyMap[$key] ?? '_auto_');
                    $sf->columnWidth = 33;
                    $sfs->add($sf);
                }
                $tfs->add($sfs);
            }

            $fs->add($tfs);
        }

        return $fs;
    }

    /**
     * Process template mappings from POST data
     */
    protected function processTemplateMappings(WireInputData $post): array
    {
        $modules = $this->wire('modules');
        $templates = $this->wire('templates');
        $jsonld = $modules->get('MarkupJsonLDSchema');
        $schemas = $jsonld->getMappableKeys();
        $mappings = [];

        foreach($templates as $template) {
            $selectedSchemas = $post->{"tm_{$template->name}_schemas"};
            if(empty($selectedSchemas)) continue;
            if(!is_array($selectedSchemas)) $selectedSchemas = [$selectedSchemas];

            $mappings[$template->name] = [];
            foreach($selectedSchemas as $schemaName) {
                if(!isset($schemas[$schemaName])) continue;
                $keyMap = [];
                foreach($schemas[$schemaName] as $key) {
                    $val = $post->{"tm_{$template->name}_{$schemaName}_{$key}"};
                    if($val && $val !== '_auto_') {
                        $keyMap[$key] = $val;
                    }
                }
                $mappings[$template->name][$schemaName] = $keyMap;
            }
        }

        return $mappings;
    }

    /**
     * Validate mappings and show warnings for invalid field references
     */
    protected function validateMappings(array $mappings): void
    {
        $templates = $this->wire('templates');

        foreach($mappings as $templateName => $schemaMap) {
            $template = $templates->get($templateName);
            if(!$template) {
                $this->warning(sprintf($this->_('Template "%s" not found'), $templateName));
                continue;
            }
            foreach($schemaMap as $schemaName => $keyMap) {
                foreach($keyMap as $key => $fieldName) {
                    if(!$template->fields->get($fieldName)) {
                        $this->warning(sprintf(
                            $this->_('Template "%s" → %s: field "%s" (mapped to key "%s") does not exist'),
                            $templateName, $schemaName, $fieldName, $key
                        ));
                    }
                }
            }
        }
    }

